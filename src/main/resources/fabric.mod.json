{
    "schemaVersion": 1,
    "id": "polylootr",
    "version": "${version}",
    "name": "PolyLootr",
    "description": "Server-side wrapper that lets vanilla Minecraft clients connect to a Lootr server. Lootr's modded blocks, items, and entities are translated to their nearest vanilla equivalents via Polymer; per-player particles indicate unlooted containers.",
    "authors": ["nickisashkir"],
    "contact": {
        "sources": "https://github.com/nickisashkir/PolyLootr",
        "issues": "https://github.com/nickisashkir/PolyLootr/issues"
    },
    "license": "MIT",
    "environment": "server",
    "entrypoints": {
        "main": [
            "dev.ashkir.polylootr.PolyLootr"
        ]
    },
    "mixins": [
        "polylootr.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=${loader_version}",
        "fabric-api": "*",
        "minecraft": ">=26.1 <26.2",
        "java": ">=25",
        "lootr": "*",
        "polymer-core": "*",
        "polymer-virtual-entity": "*"
    }
}
